{
  "manifest_version": 3,
  "name": "Colatron 3000",
  "version": "1.0",
  "description": "Abre o Google AI Studio na barra lateral do Chrome via Colatron 3000",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://aistudio.google.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "Colatron.png",
    "32": "Colatron.png",
    "48": "Colatron.png",
    "128": "Colatron.png"
  },
  "action": {
    "default_title": "Abrir AI Studio",
    "default_icon": "Colatron.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
