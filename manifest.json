{
  "manifest_version": 3,
  "name": "AI Studio Side Panel",
  "version": "1.0",
  "description": "Abre o Google AI Studio na barra lateral do Chrome",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "https://aistudio.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir AI Studio"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}